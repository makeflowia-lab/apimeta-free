# ─────────────────────────────────────────────
# Variables de entorno requeridas
# Copia este archivo a `.env.local` y rellena los valores.
# NUNCA subas `.env.local` al repositorio (está en .gitignore).
# ─────────────────────────────────────────────

# Base de datos (Neon Postgres) — usado por src/shared/lib/db.ts
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Supabase (cliente y servidor)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role (solo servidor — mantener en secreto)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
